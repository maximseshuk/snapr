{
  "name": "docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "openapi": "cd .. && go run -ldflags \"-X main.version=$(git describe --tags --abbrev=0 2>/dev/null || echo dev)\" ./cmd/snapr openapi > docs/docs/public/openapi.json",
    "build": "pnpm run openapi && rspress build",
    "dev": "rspress dev",
    "preview": "rspress preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "catalog:",
    "@fontsource-variable/geist-mono": "catalog:",
    "@rspress/core": "2.0.11",
    "@seshuk/rspress-plugin-scalar": "^0.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@rsbuild/plugin-sass": "^1.5.2",
    "@rspress/plugin-llms": "2.0.11",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "sass": "^1.99.0",
    "typescript": "catalog:"
  }
}
